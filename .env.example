# API
API_HOST=0.0.0.0
API_PORT=4000

# Database
DATABASE_URL=postgres://app:password@localhost:5432/pln_db

# Auth
JWT_SECRET=change-this-to-a-long-random-secret

# CORS - Comma-separated list of allowed origins for production
# For Tauri desktop apps, include: tauri://localhost,https://tauri.localhost
# For web frontend, include your deployed URL
# Example: ALLOWED_ORIGINS=https://your-app.onrender.com,tauri://localhost
ALLOWED_ORIGINS=tauri://localhost,https://tauri.localhost
